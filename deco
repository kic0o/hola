 void decode(struct MinHeapNode* root, char* encodedStr, char* decodedStr) {
    struct MinHeapNode* curr = root;
    int j = 0;
    for (int i = 0; encodedStr[i]; i++) {
        if (encodedStr[i] == '0')
            curr = curr->left;
        else
            curr = curr->right;

        if (isLeaf(curr)) {
            decodedStr[j++] = curr->data;
            curr = root;
        }
    }
    decodedStr[j] = '\0';
}
